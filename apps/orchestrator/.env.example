PORT=3000
HOST=0.0.0.0
REPO_URL=https://github.com/your-org/your-repo.git
WORKSPACE_BASE_PATH=/tmp/remote-dev-agent

# Required for private clones, git push, and gh pr create.
GITHUB_TOKEN=replace_with_github_pat

# Optional. Defaults to the repository origin HEAD.
DEFAULT_BRANCH=main

# Optional. Defaults to automation.
CODEX_PROFILE=automation

# Optional. Defaults to 1800000 ms (30 minutes).
CODEX_TASK_TIMEOUT_MS=1800000

# Optional. Use docker on VPS, local for development.
WORKER_EXECUTION_MODE=local

# Required only when WORKER_EXECUTION_MODE=docker.
WORKER_IMAGE=ai-orchestrator-worker:latest
WORKER_WORKSPACE_VOLUME=ai-orchestrator-worker-workspaces
CODEX_HOME_VOLUME=ai-orchestrator-codex-home
