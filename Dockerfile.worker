FROM node:22-bookworm-slim AS build

WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates curl git gnupg \
  && install -m 0755 -d /etc/apt/keyrings \
  && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg -o /etc/apt/keyrings/githubcli-archive-keyring.gpg \
  && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
  && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" > /etc/apt/sources.list.d/github-cli.list \
  && apt-get update \
  && apt-get install -y --no-install-recommends gh \
  && rm -rf /var/lib/apt/lists/*

RUN corepack enable && corepack prepare pnpm@10.12.1 --activate
RUN npm install -g @openai/codex@latest
RUN git config --system user.name "AI Orchestrator" \
  && git config --system user.email "ai-orchestrator@example.invalid"

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.json tsconfig.base.json ./
COPY apps/orchestrator/package.json apps/orchestrator/package.json
COPY apps/telegram-bot/package.json apps/telegram-bot/package.json
COPY apps/worker/package.json apps/worker/package.json
COPY packages/codex-runner/package.json packages/codex-runner/package.json
COPY shared/types/package.json shared/types/package.json

RUN pnpm install --frozen-lockfile

COPY apps/worker apps/worker
COPY packages/codex-runner packages/codex-runner
COPY shared/types shared/types

RUN pnpm --filter @remote-dev-agent/types build \
  && pnpm --filter @remote-dev-agent/codex-runner build \
  && pnpm --filter @remote-dev-agent/worker build

CMD ["node", "apps/worker/dist/cli.js"]
